datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

model User {
  id                 String                  @id @default(uuid())
  publicId           String                  @unique // 8-digit unique ID (Unique, Indexed, Searchable)
  username           String                  @unique // Unique username for handles / profiles
  displayNickname    String?                 // Visible name (Ali Al Iraqi)
  email              String?                 @unique
  passwordHash       String?
  role               String                  @default("USER") // USER, GUEST, ADMIN, SUPERADMIN
  deviceId           String
  referralCode       String                  @unique
  referredByCode     String?
  avatar             String                  @default("avatar_1")
  age                Int?
  gender             String?                 // MALE, FEMALE
  bio                String?
  whatsapp           String?
  phoneNumber        String?                 // Phone number without country code
  countryCode        String?                 // e.g. +964, +966, +971
  lastLoginAt        DateTime?               // Last login timestamp
  createdAt          DateTime                @default(now())
  roundsPlayed       Int                     @default(0)
  roundsWon          Int                     @default(0)
  badge              String?
  isVerified         Boolean                 @default(false)
  
  // Ban fields
  isBanned           Boolean                 @default(false)
  banExpiresAt       DateTime?               // Null = permanent, Date = temporary ban expiration
  banReason          String?
  
  wallet             Wallet?
  bets               Bet[]
  transactions       Transaction[]
  orders             Order[]
  deposits           Deposit[]
  withdrawals        Withdrawal[]
  taskProgress       TaskProgress[]
  pushTokens         PushNotificationToken[]
  
  invitationsSent    Referral[]              @relation("InviterRelation")
  invitationReceived Referral?               @relation("InviteeRelation")
  supportMessages    SupportMessage[]
}

model Wallet {
  id          String   @id @default(uuid())
  userId      String   @unique
  freeBalance Float    @default(1000.0) // Starting Free Coins
  cashBalance Float    @default(0.0)
  updatedAt   DateTime @updatedAt
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Round {
  id                String          @id @default(uuid())
  status            String          @default("BETTING") // BETTING, LOCKED, CALCULATING, REVEALING, FINALIZING, ENDED
  currencyMode      String          @default("FREE_ONLY") // FREE_ONLY, CASH_ONLY, BOTH_DISABLED
  winningBox        Int?            // 0-7
  winningMultiplier Float?
  totalBetsFree     Float           @default(0.0)
  totalBetsCash     Float           @default(0.0)
  totalPayoutFree   Float           @default(0.0)
  totalPayoutCash   Float           @default(0.0)
  startAt           DateTime        @default(now())
  sequenceNumber    Int             @default(0)
  
  bets              Bet[]
  snapshots         RoundSnapshot[]
  eventLogs         EventLog[]
}

model Bet {
  id                String   @id @default(uuid())
  userId            String
  roundId           String
  clientBetId       String   // UUID generated by client to prevent double betting
  boxIndex          Int      // 0-7
  amount            Float
  currency          String   // FREE, CASH
  status            String   @default("PENDING") // PENDING, WON, LOST
  winAmount         Float    @default(0.0)
  createdAt         DateTime @default(now())
  
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  round             Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@unique([userId, roundId, clientBetId])
}

model Transaction {
  id          String   @id @default(uuid())
  userId      String
  amount      Float
  currency    String   // FREE, CASH
  type        String   // DEPOSIT, WITHDRAWAL, BET_PLACE, BET_WIN, BET_REFUND, REFERRAL_BONUS, DAILY_TASK_BONUS
  description String
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Deposit {
  id             String   @id @default(uuid())
  userId         String
  amount         Float
  status         String   @default("PENDING") // PENDING, APPROVED, REJECTED
  transactionRef String?
  rejectionReason String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  receiptImageUrl String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Withdrawal {
  id             String   @id @default(uuid())
  userId         String
  amount         Float
  status         String   @default("PENDING") // PENDING, APPROVED, REJECTED
  transactionRef String?
  rejectionReason String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Referral {
  id          String   @id @default(uuid())
  inviterId   String
  inviteeId   String   @unique
  bonusPaid   Boolean  @default(false)
  createdAt   DateTime @default(now())
  
  inviter     User     @relation("InviterRelation", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee     User     @relation("InviteeRelation", fields: [inviteeId], references: [id], onDelete: Cascade)
}

model DailyTask {
  id             String         @id @default(uuid())
  key            String         @unique
  title          String
  description    String
  goalCount      Int
  rewardAmount   Float
  rewardCurrency String         // FREE, CASH
  isEnabled      Boolean        @default(true)
  type           String         @default("DAILY") // DAILY, ONETIME, SOCIAL
  actionType     String?
  linkUrl        String?
  progress       TaskProgress[]
}

model TaskProgress {
  id          String    @id @default(uuid())
  userId      String
  taskId      String
  count       Int       @default(0)
  isCompleted Boolean   @default(false)
  claimedAt   DateTime?
  updatedAt   DateTime  @updatedAt
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  task        DailyTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId])
}

model SystemConfig {
  id                     String   @id @default("singleton")
  minBet                 Float    @default(10.0)
  maxBet                 Float    @default(10000.0)
  roundDurationBetting   Int      @default(20) // in seconds
  roundDurationCalcul    Int      @default(3)  // in seconds
  roundDurationReveal    Int      @default(5)  // in seconds
  isFreeEnabled          Boolean  @default(true)
  isCashEnabled          Boolean  @default(true)
  historyLength          Int      @default(20)
  isMaintenanceMode      Boolean  @default(false)
  maintenanceMessage     String   @default("The game is currently under maintenance. Please try again later.")
  inviteRewardInviter    Float    @default(500.0)
  inviteRewardInvitee    Float    @default(200.0)
  dailyInviteLimit       Int      @default(5)
  isReferralActive       Boolean  @default(true)
  supportTelegram        String   @default("")
  supportWhatsApp        String   @default("")
  socialFacebook         String   @default("")
  socialInstagram        String   @default("")
  socialTikTok           String   @default("")
  socialWhatsApp         String   @default("")
  socialTelegram         String   @default("")
  exchangeRateIqd        Float    @default(1600.0)
}

model HousePool {
  id             String   @id @default(uuid())
  type           String   @unique // FREE, CASH
  balance        Float    @default(1000000.0) // Initial house seed
  updatedAt      DateTime @updatedAt
}

model HousePoolLog {
  id          String   @id @default(uuid())
  poolType    String   // FREE, CASH
  amountChange Float
  type        String   // BET_REVENUE, PAYOUT_EXPENSE, ADMIN_ADJUSTMENT, SIMULATION
  referenceId String?
  createdAt   DateTime @default(now())
}

model PushNotificationToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String   // ANDROID, IOS
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EventLog {
  globalEventId  Int      @id @default(autoincrement())
  roundId        String?
  requestId      String?
  eventType      String   // BET_PLACED, BET_REJECTED, ROUND_START, ROUND_END, PAYOUT, ADMIN_OVERRIDE, WALLET_UPDATE, SYSTEM_ALERT
  userId         String?
  message        String
  sequenceNumber Int      @default(0)
  createdAt      DateTime @default(now())
  
  round          Round?   @relation(fields: [roundId], references: [id], onDelete: SetNull)
}

model RoundSnapshot {
  id               String   @id @default(uuid())
  roundId          String
  poolFreeBalance  Float
  poolCashBalance  Float
  totalBetsFree    Float
  totalBetsCash    Float
  betsJson         String   // JSON string representing bets
  resultBox        Int
  isOverride       Boolean  @default(false)
  overrideAdminId  String?
  createdAt        DateTime @default(now())
  
  round            Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
}

model SupportMessage {
  id        String   @id @default(uuid())
  userId    String
  sender    String   // USER, AGENT
  message   String?
  imageUrl  String?
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FinanceLog {
  id          String   @id @default(uuid())
  type        String   // REVENUE, EXPENSE
  category    String   // SERVER, ADS, STORE, GAME, MANUAL
  amount      Float
  currency    String   // IQD, USD, COINS
  description String?
  createdAt   DateTime @default(now())
}


model PaymentMethod {
  id            String   @id @default(uuid())
  name          String   @unique // Zain Cash, USDT, Asiacell
  currency      String   // IQD, USD
  accountNumber String   // Phone number or wallet address
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  priceCoins  Float
  imageUrl    String?
  category    String   // GLOBAL_CARDS, CHAT_APPS, GAMES, CASH_WITHDRAWAL
  isActive    Boolean  @default(true)
  stock       Int      @default(-1) // -1 for unlimited
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
}

model Order {
  id             String   @id @default(uuid())
  userId         String
  productId      String
  priceCoins     Float
  status         String   @default("PENDING") // PENDING, DELIVERED, REJECTED
  deliveryDetails String? // Code or proof of transfer
  userNotes       String? // User provided notes, e.g., Zain Cash number
  rejectionReason String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}
